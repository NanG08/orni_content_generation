# Copy to .env. Leave USE_MOCKS=true to run the whole demo with NO credentials.
# On the hackathon day: set USE_MOCKS=false, paste the key, CONFIRM every model id.

USE_MOCKS=true
GEMINI_API_KEY=

# Model ids (verified against a live hackathon key on 2026-07-11).
# NOTE: the *-live-preview models are bidi-audio ONLY (they 404 on
# generateContent), so intent parsing + text translation use gemini-3.5-flash.
MODEL_INTENT=gemini-3.5-flash
MODEL_LIVE=gemini-3.1-flash-live-preview
MODEL_TRANSLATE=gemini-3.5-flash
MODEL_IMAGE=gemini-3.1-flash-lite-image
MODEL_VIDEO=gemini-omni-flash-preview
MODEL_TTS=gemini-3.1-flash-tts-preview

# Optional non-Google voice providers (reliable fallbacks). Leave blank to use
# the Google/browser path. If set, they take over ONLY the voice legs.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

HOST=127.0.0.1
PORT=8000
